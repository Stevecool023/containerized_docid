# External port publishing
FRONTEND_PORT=3000
BACKEND_PORT=5001
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL
POSTGRES_DB=docid_db
POSTGRES_USER=docid
POSTGRES_PASSWORD=docid
DATABASE_URL=postgresql://docid:docid@db:5432/docid_db

# Redis
CELERY_BROKER_URL=redis://redis:6379/0

# Backend
FLASK_ENV=production
FLASK_APP=run.py
SECRET_KEY=change_me
JWT_SECRET_KEY=change_me
APPLICATION_BASE_URL=http://localhost:3000
UPLOADS_DIRECTORY=/app/uploads
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Frontend
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_NODE_URL=http://localhost:3000
BACKEND_API_URL=http://backend:5001/api
API_BASE_URL=http://backend:5001/api/v1
BACKEND_UPLOAD_ORIGIN=http://backend:5001
NEXT_IMAGE_REMOTE_HOSTS=localhost,docid.africapidalliance.org
